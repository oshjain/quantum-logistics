# ── Convex Backend ──────────────────────────────────
# Local dev URL (set automatically by `pnpm dev:backend`)
VITE_CONVEX_URL=http://127.0.0.1:3210

# ── OIDC Authentication ─────────────────────────────
# Replace with your OIDC provider's values.
# Works with any standard OIDC provider (Auth0, Azure AD, Keycloak, etc.)
VITE_OIDC_AUTHORITY=https://your-oidc-provider.com
VITE_OIDC_CLIENT_ID=your-client-id
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Convex Backend Auth (set via `npx convex env set`) ──
CONVEX_OIDC_AUTHORITY=https://your-oidc-provider.com
CONVEX_OIDC_CLIENT_ID=your-client-id
